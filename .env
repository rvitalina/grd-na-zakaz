# Скопируйте в файл .env в корне проекта и заполните значения.
# Пароль приложения Яндекс: https://id.yandex.ru/security/app-passwords

PORT=4000

SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true

# Обычно полный адрес почты, с которой идёт отправка
SMTP_USER=grd-manager@yandex.ru
SMTP_PASS=ваш_пароль_приложения_яндекс

# Куда приходят заявки (можно не указывать — по умолчанию grd-manager@yandex.ru)
MAIL_TO=grd-manager@yandex.ru

# От кого письмо (необязательно)
# MAIL_FROM=Titan-GS <grd-manager@yandex.ru>
